<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.WeSocial" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/main_colour</item> <!-- Content background -->
        <item name="colorPrimaryVariant">@color/black</item> <!-- Notification bar -->
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/main_colour</item>
        <item name="colorSecondaryVariant">@color/main_colour</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/main_colour</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.WeSocial.ActionBar" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/main_colour</item> <!-- Content background -->
        <item name="colorPrimaryVariant">@color/black</item> <!-- Notification bar -->
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/main_colour</item>
        <item name="colorSecondaryVariant">@color/main_colour</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/main_colour</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="PreferenceScreen" parent="Theme.AppCompat">
        <item name="android:textColor">@color/light_main_colour</item>
        <item name="android:textColorPrimary">@color/light_main_colour</item>
        <item name="android:background">@color/black</item>
    </style>
    <style name="AlertDialogCustom" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:colorAccent">@color/main_colour</item>
        <item name="android:color">@color/main_colour</item>
    </style>
</resources>