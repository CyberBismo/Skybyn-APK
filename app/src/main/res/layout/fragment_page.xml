<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BrowsePages">

    <TextView
        android:id="@+id/lblBrowsePagesTitle"
        android:layout_width="0dp"
        android:layout_height="@dimen/headerHeight"
        android:background="?attr/colorPrimary"
        android:fontFamily="@font/nexalight"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:text="@string/browse_page"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="TextContrastCheck" />

    <TextView
        android:id="@+id/txtCreateNewPage"
        android:layout_width="120dp"
        android:layout_height="21dp"
        android:layout_marginTop="8dp"
        android:drawablePadding="5dp"
        android:fontFamily="@font/nexalight"
        android:gravity="center_vertical"
        android:text="@string/create_new_page"
        android:textColor="@color/white"
        android:textSize="10sp"
        app:drawableStartCompat="@drawable/create_new_page"
        app:drawableTint="@color/white"
        app:layout_constraintEnd_toEndOf="@+id/lblBrowsePagesTitle"
        app:layout_constraintHorizontal_bias="0.95"
        app:layout_constraintStart_toStartOf="@+id/lblBrowsePagesTitle"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/browsePagesRecyclerView"
        android:layout_width="0dp"
        android:layout_height="646dp"
        android:isScrollContainer="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

    </androidx.recyclerview.widget.RecyclerView>

    <SearchView
        android:id="@+id/pageSearchView"
        android:layout_width="412dp"
        android:layout_height="28dp"
        android:layout_marginBottom="4dp"
        android:queryHint="@string/search_for_pages"
        android:theme="@style/SearchViewTheme"
        app:layout_constraintBottom_toTopOf="@+id/tabLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lblBrowsePagesTitle"
        app:layout_constraintVertical_bias="1.0">

    </SearchView>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@+id/browsePagesRecyclerView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:tabIndicatorColor="?attr/colorPrimary"
        app:tabRippleColor="?attr/colorPrimary"
        app:tabSelectedTextColor="@color/mainColour"
        app:tabTextColor="?attr/colorPrimary">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pages" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_pages" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/joined_pages" />
    </com.google.android.material.tabs.TabLayout>

</androidx.constraintlayout.widget.ConstraintLayout>