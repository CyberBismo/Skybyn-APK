<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/friendCardView"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    app:cardBackgroundColor="@color/dark_gray_2"
    app:cardElevation="10dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/txtUserSearchUsername"
            android:layout_width="200dp"
            android:layout_height="27dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="88dp"
            android:fontFamily="@font/nexabold"
            android:gravity="center_vertical"
            android:singleLine="true"
            android:text="@string/username"
            android:textColor="@color/white"
            app:layout_constraintBottom_toTopOf="@+id/txtUserSearchNickname"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.115" />

        <TextView
            android:id="@+id/txtUserSearchNickname"
            android:layout_width="200dp"
            android:layout_height="27dp"
            android:layout_marginEnd="88dp"
            android:layout_marginBottom="116dp"
            android:fontFamily="@font/nexabold"
            android:gravity="center_vertical"
            android:singleLine="true"
            android:text="@string/Nickname"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.mikhaellopez.circularimageview.CircularImageView
            android:id="@+id/imgUserSearchProfilePicture"
            android:layout_width="81dp"
            android:layout_height="77dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:background="@color/transparent_full"
            app:civ_border_color="@color/light_main_colour"
            app:civ_border_width="2dp"
            app:civ_shadow_color="@color/white"
            app:civ_shadow_radius="5dp"
            app:layout_constraintEnd_toStartOf="@+id/txtUserSearchUsername"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/btnUserSearchAddFriend"
            android:layout_width="74dp"
            android:layout_height="30dp"
            android:layout_marginStart="120dp"
            android:background="@drawable/button_selector_red"
            android:text="@string/block"
            android:textColor="@color/white"
            android:textSize="12sp"
            app:layout_constraintBottom_toTopOf="@+id/txtUserSearchOnline"
            app:layout_constraintEnd_toStartOf="@+id/btnRemoveFriend"
            app:layout_constraintHorizontal_bias="0.272"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imgUserSearchProfilePicture"
            app:layout_constraintVertical_bias="0.0"
            tools:ignore="TouchTargetSizeCheck" />

        <Button
            android:id="@+id/btnRemoveFriend"
            android:layout_width="74dp"
            android:layout_height="30dp"
            android:layout_marginEnd="132dp"
            android:layout_marginBottom="68dp"
            android:background="@color/dark_gray"
            android:text="@string/remove"
            android:textColor="@color/white"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="TouchTargetSizeCheck" />

        <TextView
            android:id="@+id/txtUserSearchOnline"
            android:layout_width="199dp"
            android:layout_height="22dp"
            android:layout_marginBottom="28dp"
            android:background="@drawable/online_status"
            android:foregroundGravity="center_horizontal"
            android:gravity="center_horizontal"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.113"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>