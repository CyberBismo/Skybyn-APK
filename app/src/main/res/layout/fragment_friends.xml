<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    tools:context=".Friends">

    <!-- TODO: Update blank fragment layout -->

    <TextView
        android:id="@+id/txtFriendsTitle"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:layout_gravity="center_horizontal|center_vertical"
        android:layout_marginTop="10dp"
        android:gravity="center_horizontal|center_vertical"
        android:text="@string/Friends"
        android:textColor="@color/white"
        android:textSize="16sp" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/btnShowFriendsList"
            android:layout_width="120dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:background="@color/dark_gray_2"
            android:fontFamily="sans-serif-light"
            android:text="@string/Friends"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnShowFriendsRequestsList"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            tools:ignore="TouchTargetSizeCheck,DuplicateSpeakableTextCheck" />

        <Button
            android:id="@+id/btnShowFriendsRequestsList"
            android:layout_width="120dp"
            android:layout_height="34dp"
            android:layout_marginEnd="20dp"
            android:background="@color/dark_gray_2"
            android:fontFamily="sans-serif-light"
            android:text="@string/friend_requests"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnShowBlockedFriendsList"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            tools:ignore="TouchTargetSizeCheck" />

        <Button
            android:id="@+id/btnShowBlockedFriendsList"
            android:layout_width="120dp"
            android:layout_height="34dp"
            android:layout_marginEnd="4dp"
            android:background="@color/red"
            android:fontFamily="sans-serif-light"
            android:text="@string/blocked"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            tools:ignore="TouchTargetSizeCheck" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchRecyclervView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>