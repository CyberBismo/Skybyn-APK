<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRelativeLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context="social.app.wesocial.LoginRegisterForgot">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/loginProgressView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.7"
        android:background="@color/white"
        android:clickable="false"
        android:elevation="1000dp"
        android:filterTouchesWhenObscured="false"
        android:foregroundGravity="center_vertical|center_horizontal"
        android:scaleType="fitCenter"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <ImageView
        android:id="@+id/Logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        app:srcCompat="@mipmap/ic_launcher_foreground" />

    <FrameLayout
        android:id="@+id/signin_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="75dp"
        android:layout_marginTop="100dp"
        android:background="@color/white"
        android:visibility="visible">

        <TextView
            android:id="@+id/signin_form_title"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="30dp"
            android:lineHeight="24dp"
            android:text="@string/sign_in"
            android:textColor="@color/main_colour"
            android:textSize="24dp" />

        <EditText
            android:id="@+id/txtUsername"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="90dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/textview_rounded_corner_gray"
            android:drawableLeft="@drawable/user"
            android:drawablePadding="@dimen/drawable_padding"
            android:gravity="center_vertical"
            android:hint="Username"
            android:inputType="textPersonName"
            android:paddingHorizontal="10dp"
            android:textColor="@color/main_colour"
            android:textColorHint="@color/main_colour" />

        <EditText
            android:id="@+id/txtPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="150dp"
            android:background="@drawable/textview_rounded_corner_gray"
            android:drawableStart="@drawable/password"
            android:drawablePadding="@dimen/drawable_padding"
            android:ems="10"
            android:hint="@string/password"
            android:inputType="textPassword"
            android:paddingHorizontal="10dp"
            android:textColor="@color/main_colour"
            android:textColorHint="@color/main_colour" />

        <Button
            android:id="@+id/BtnProcessLogin"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="220dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/button_selector"
            android:backgroundTint="@color/main_colour"
            android:text="@string/sign_in"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/loginShowForgotForm"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="400dp"
            android:background="@color/transparent_full"
            android:backgroundTint="@color/black"
            android:text="@string/forgot_password"
            android:textColor="@color/main_colour"
            tools:ignore="TouchTargetSizeCheck" />

        <Button
            android:id="@+id/loginShowSignupForm"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="440dp"
            android:background="@color/transparent_full"
            android:backgroundTint="@color/black"
            android:text="@string/sign_up"
            android:textColor="@color/main_colour"
            tools:ignore="TouchTargetSizeCheck,DuplicateClickableBoundsCheck" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/signup_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="75dp"
        android:layout_marginTop="100dp"
        android:background="@color/white"
        android:visibility="invisible">

        <TextView
            android:id="@+id/signup_form_title"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="30dp"
            android:lineHeight="24dp"
            android:text="@string/sign_up"
            android:textColor="@color/main_colour"
            android:textSize="24dp" />

        <EditText
            android:id="@+id/Username"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="90dp"
            android:background="@drawable/textview_rounded_corner_gray"
            android:drawableStart="@drawable/user"
            android:drawablePadding="@dimen/drawable_padding"
            android:hint="@string/username"
            android:inputType="textPersonName"
            android:paddingHorizontal="10dp"
            android:textColor="@color/main_colour"
            android:textColorHint="@color/main_colour" />

        <EditText
            android:id="@+id/Password"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="150dp"
            android:background="@drawable/textview_rounded_corner_gray"
            android:drawableStart="@drawable/password"
            android:drawablePadding="@dimen/drawable_padding"
            android:ems="10"
            android:hint="@string/password"
            android:inputType="textPassword"
            android:paddingHorizontal="10dp"
            android:textColor="@color/main_colour"
            android:textColorHint="@color/main_colour" />

        <EditText
            android:id="@+id/cPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="210dp"
            android:background="@drawable/textview_rounded_corner_gray"
            android:drawableStart="@drawable/password"
            android:drawablePadding="@dimen/drawable_padding"
            android:ems="10"
            android:hint="@string/confirm_password"
            android:inputType="textPassword"
            android:paddingHorizontal="10dp"
            android:textColor="@color/main_colour"
            android:textColorHint="@color/main_colour" />

        <EditText
            android:id="@+id/Email"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="270dp"
            android:background="@drawable/textview_rounded_corner_gray"
            android:drawableStart="@drawable/email"
            android:drawablePadding="@dimen/drawable_padding"
            android:hint="@string/email"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="10dp"
            android:textColor="@color/main_colour"
            android:textColorHint="@color/main_colour" />

        <Button
            android:id="@+id/btnProcessSignUp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="330dp"
            android:background="@drawable/button_selector"
            android:backgroundTint="@color/main_colour"
            android:text="@string/sign_up"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/signupShowForgotForm"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="400dp"
            android:background="@color/transparent_full"
            android:backgroundTint="@color/black"
            android:text="@string/forgot_password"
            android:textColor="@color/main_colour"
            tools:ignore="TouchTargetSizeCheck" />

        <Button
            android:id="@+id/signupShowLoginForm"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="480dp"
            android:background="@color/transparent_full"
            android:backgroundTint="@color/black"
            android:text="@string/sign_in"
            android:textColor="@color/main_colour"
            tools:ignore="TouchTargetSizeCheck" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/forgot_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="75dp"
        android:layout_marginTop="100dp"
        android:background="@color/white"
        android:visibility="invisible">

        <TextView
            android:id="@+id/forgot_form_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="30dp"
            android:lineHeight="24dp"
            android:text="Forgot password?"
            android:textColor="@color/main_colour"
            android:textSize="24dp" />

        <EditText
            android:id="@+id/forgot_email"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="90dp"
            android:background="@drawable/textview_rounded_corner_gray"
            android:drawableStart="@drawable/email"
            android:drawablePadding="@dimen/drawable_padding"
            android:hint="Email address"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="10dp"
            android:textColor="@color/main_colour"
            android:textColorHint="@color/main_colour" />

        <Button
            android:id="@+id/btnSendPasswordRequest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="170dp"
            android:background="@drawable/button_selector"
            android:backgroundTint="@color/main_colour"
            android:drawableStart="@drawable/password"
            android:drawablePadding="5dp"
            android:text="@string/Continue"
            android:textColor="@color/white"
            android:textColorHint="@color/light_gray" />

        <Button
            android:id="@+id/forgotShowSignupForm"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="440dp"
            android:background="@color/transparent_full"
            android:backgroundTint="@color/black"
            android:text="@string/sign_up"
            android:textColor="@color/main_colour"
            tools:ignore="TouchTargetSizeCheck,DuplicateClickableBoundsCheck" />

        <Button
            android:id="@+id/forgotShowLoginForm"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="480dp"
            android:background="@color/transparent_full"
            android:backgroundTint="@color/black"
            android:text="@string/sign_in"
            android:textColor="@color/main_colour"
            tools:ignore="TouchTargetSizeCheck" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/email_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="75dp"
        android:layout_marginTop="100dp"
        android:visibility="invisible">

        <TextView
            android:id="@+id/verify_email_form_title"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="30dp"
            android:lineHeight="24dp"
            android:text="@string/email_verification"
            android:textColor="@color/main_colour"
            android:textSize="24dp" />

        <TextView
            android:id="@+id/verify_email_check"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="80dp"
            android:lineHeight="24dp"
            android:textColor="@color/main_colour"
            android:textSize="20sp"/>

        <Button
            android:id="@+id/btnSendVerifyEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="150dp"
            android:background="@drawable/button_selector"
            android:backgroundTint="@color/main_colour"
            android:text="@string/verify_email"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnCancelVerifyEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="210dp"
            android:background="@drawable/button_selector"
            android:backgroundTint="@color/black"
            android:text="Cancel"
            android:textColor="@color/white" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/verify_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginHorizontal="75dp"
        android:layout_marginTop="100dp"
        android:visibility="invisible">

        <TextView
            android:id="@+id/verify_form_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="30dp"
            android:gravity="center_horizontal"
            android:lineHeight="24dp"
            android:text="@string/enter_the_verification_code"
            android:textColor="@color/main_colour"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/txtOTC"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="110dp"
            android:background="#11FFFFFF"
            android:gravity="center"
            android:hint="@string/One_Time_Code"
            android:inputType="textPassword"
            android:paddingHorizontal="10dp"
            android:textColor="@color/white"
            android:textColorHint="@color/white" />

        <Button
            android:id="@+id/btnVerifyOTC"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="180dp"
            android:background="@drawable/button_selector"
            android:backgroundTint="@color/main_colour"
            android:text="@string/verify"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/lblCloseVerify"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="260dp"
            android:gravity="center_horizontal"
            android:lineHeight="24dp"
            android:text="@string/cancel_verification"
            android:textColor="@color/main_colour"
            android:textSize="20sp" />

    </FrameLayout>
</RelativeLayout>