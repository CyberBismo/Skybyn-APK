<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/txtChatMessageOut"
        android:layout_width="250dp"
        android:layout_height="wrap_content"

        android:layout_marginEnd="10dp"
        android:layout_marginBottom="5dp"
        android:layout_weight="1"
        android:background="@drawable/outgoing_chat_bubble"
        android:gravity="end"
        android:inputType="textMultiLine|textImeMultiLine|textNoSuggestions"
        android:padding="13dp"
        android:textColor="@color/white"
        android:textDirection="anyRtl"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@+id/txtChatMessageOutDate"
        app:layout_constraintEnd_toStartOf="@+id/imgChatMessageOutProfilePicture"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        tools:ignore="Deprecated,TouchTargetSizeCheck,SpeakableTextPresentCheck,SpeakableTextPresentCheck" />

    <com.mikhaellopez.circularimageview.CircularImageView
        android:id="@+id/imgChatMessageOutProfilePicture"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="16dp"
        android:layout_weight="1"
        android:background="@color/transparent_full"
        app:civ_border_color="@color/white"
        app:civ_border_width="1dp"
        app:civ_shadow_color="@color/white"
        app:civ_shadow_radius="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtChatMessageOutDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="68dp"
        android:layout_marginBottom="2dp"
        android:layout_weight="1"
        android:inputType="textMultiLine|textImeMultiLine|textNoSuggestions"
        android:text="TextView"
        android:textColor="@color/dark"
        android:textDirection="ltr"
        android:textSize="11sp"
        android:textStyle="italic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="TouchTargetSizeCheck" />

</androidx.constraintlayout.widget.ConstraintLayout>