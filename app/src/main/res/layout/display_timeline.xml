<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/black"
    android:paddingTop="10dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/displayTimelineCardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.028">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/black">

            <com.mikhaellopez.circularimageview.CircularImageView
                android:id="@+id/imgTimelinePostProfilePicture"
                android:layout_width="39dp"
                android:layout_height="35dp"
                android:layout_marginTop="16dp"
                android:background="@color/transparent_full"
                app:civ_border_color="@color/white"
                app:civ_border_width="1dp"
                app:civ_shadow_color="@color/white"
                app:civ_shadow_radius="5dp"
                app:layout_constraintEnd_toStartOf="@+id/txtTimelinePostUsername"
                app:layout_constraintHorizontal_bias="0.777"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtTimelinePostUsername"
                android:layout_width="200dp"
                android:layout_height="27dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="84dp"
                android:fontFamily="@font/nexabold"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:text="@string/app_name"
                android:textColor="@color/white"
                app:layout_constraintBottom_toTopOf="@+id/txtTimelinePostDate"
                app:layout_constraintEnd_toStartOf="@+id/imgTimelinePostDelete"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0" />

            <TextView
                android:id="@+id/txtTimelinePostLikes"
                android:layout_width="93dp"
                android:layout_height="20dp"
                android:layout_marginEnd="108dp"
                android:ellipsize="end"
                android:fontFamily="@font/nexalight"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/imgTimelinePostComment"
                app:layout_constraintTop_toBottomOf="@+id/txtTimelinePostContent"
                app:layout_constraintVertical_bias="0.434" />

            <TextView
                android:id="@+id/txtTimelinePostComments"
                android:layout_width="80dp"
                android:layout_height="20dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="52dp"
                android:ellipsize="end"
                android:fontFamily="@font/nexalight"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtTimelinePostContent"
                app:layout_constraintVertical_bias="1.0" />

            <TextView
                android:id="@+id/txtTimelinePostDate"
                android:layout_width="257dp"
                android:layout_height="19dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/nexalight"
                android:gravity="top|center_vertical"
                android:text="@string/app_name"
                android:textColor="@color/white"
                android:textSize="11sp"
                app:layout_constraintBottom_toTopOf="@+id/txtTimelinePostContent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.455"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/txtTimelinePostContent"
                android:layout_width="351dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="112dp"
                android:fontFamily="@font/nexabold"
                android:textColor="@color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.619"
                app:layout_constraintStart_toStartOf="parent" />

            <ImageView
                android:id="@+id/imgTimelinePostComment"
                android:layout_width="25dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:minWidth="48dp"
                android:minHeight="48dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/txtTimelinePostComments"
                app:layout_constraintTop_toBottomOf="@+id/txtTimelinePostContent"
                app:layout_constraintVertical_bias="0.434"
                app:srcCompat="@drawable/comment"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

            <ImageView
                android:id="@+id/imgTimelinePostDelete"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="4dp"
                android:visibility="invisible"
                app:layout_constraintBottom_toTopOf="@+id/txtTimelinePostDate"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.842"
                app:srcCompat="@drawable/delete" />

            <com.like.LikeButton
                android:id="@+id/imgShowTimelinePostLike"
                android:layout_width="25dp"
                android:layout_height="20dp"
                android:layout_marginStart="24dp"
                app:anim_scale_factor="2"
                app:circle_end_color="@color/light_main_colour"
                app:circle_start_color="@color/red"
                app:icon_size="25dp"
                app:icon_type="thumb"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtTimelinePostContent"
                app:layout_constraintVertical_bias="0.434"
                app:like_drawable="@drawable/liked"
                app:unlike_drawable="@drawable/like" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>