<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="140dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/notificationCardView"
        android:layout_width="396dp"
        android:layout_height="118dp"
        android:clickable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.027">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="401dp"
            android:layout_height="match_parent"
            android:background="@color/black">


            <TextView
                android:id="@+id/lblnotificationdetails"
                android:layout_width="304dp"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/nexalight"
                android:foregroundGravity="center_horizontal"
                android:gravity="center_vertical"
                android:paddingStart="5dp"
                android:text="@string/test_notification_details"
                android:textColor="@color/white"
                android:textSize="10sp"
                app:layout_constraintBottom_toTopOf="@+id/imgnotificationdata"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.876"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/lblNotificationTitle"
                android:layout_width="300dp"
                android:layout_height="29dp"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/nexalight"
                android:foregroundGravity="center_horizontal"
                android:gravity="center_vertical"
                android:paddingStart="5dp"
                android:text="@string/test_notification_title"
                android:textColor="@color/white"
                android:textColorHint="@color/white"
                android:textSize="10sp"
                app:layout_constraintBottom_toTopOf="@+id/lblnotificationdetails"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.194" />

            <TextView
                android:id="@+id/lblnotificationdate"
                android:layout_width="136dp"
                android:layout_height="17dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"
                android:fontFamily="@font/nexalight"
                android:gravity="center_vertical"
                android:paddingStart="5dp"
                android:textColor="@color/white"
                android:textSize="10sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/imgnotificationdata"
                android:layout_width="18dp"
                android:layout_height="17dp"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/clock"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/lblnotificationdate"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="parent" />

            <com.mikhaellopez.circularimageview.CircularImageView
                android:id="@+id/imgNotificationSender"
                android:layout_width="57dp"
                android:layout_height="54dp"
                android:layout_marginStart="4dp"
                android:background="@color/transparent_full"
                app:civ_border_color="@color/white"
                app:civ_border_width="4dp"
                app:civ_shadow_color="@color/white"
                app:civ_shadow_radius="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/lblNotificationTitle"
                app:layout_constraintHorizontal_bias="0.444"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.109" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>