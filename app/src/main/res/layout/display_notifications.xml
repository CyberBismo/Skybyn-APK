<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="160dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/notificationCardView"
        android:layout_width="396dp"
        android:layout_height="122dp"
        android:background="@color/dark_gray_2"
        android:clickable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.027">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="434dp"
            android:layout_height="match_parent"
            android:background="@color/transparent_full">


            <TextView
                android:id="@+id/lblNotificationContent"
                android:layout_width="303dp"
                android:layout_height="54dp"
                android:layout_marginBottom="32dp"
                android:fontFamily="@font/nexalight"
                android:foregroundGravity="center_horizontal"
                android:paddingStart="5dp"
                android:text="@string/test_notification_details"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="italic"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.625"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/lblNotificationTitle"
                android:layout_width="300dp"
                android:layout_height="25dp"
                android:fontFamily="@font/nexalight"
                android:foregroundGravity="center_horizontal"
                android:gravity="center_vertical"
                android:paddingStart="5dp"
                android:text="@string/test_notification_title"
                android:textColor="@color/white"
                android:textColorHint="@color/white"
                android:textSize="14sp"
                app:layout_constraintBottom_toTopOf="@+id/lblNotificationContent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.634"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.727" />

            <TextView
                android:id="@+id/lblNotificationDate"
                android:layout_width="136dp"
                android:layout_height="17dp"
                android:layout_marginEnd="60dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/nexalight"
                android:gravity="center_vertical"
                android:paddingStart="5dp"
                android:textColor="@color/white"
                android:textSize="10sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <ImageView
                android:id="@+id/imgNotificationSender"
                android:layout_width="59dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/lblNotificationTitle"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.121"
                tools:srcCompat="@tools:sample/avatars" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>