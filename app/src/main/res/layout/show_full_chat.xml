<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainConstraintLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_weight="3"
    android:background="@color/white"
    android:orientation="vertical"
    android:visibility="visible">


    <androidx.cardview.widget.CardView
        android:id="@+id/sendMessageCardView"
        android:layout_width="409dp"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:cardBackgroundColor="@color/transparent_full"
        app:cardElevation="1dp"
        app:contentPaddingBottom="10dp"
        app:contentPaddingTop="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnChatSendMessage"
            android:layout_width="34dp"
            android:layout_height="28dp"

            android:layout_gravity="center_vertical"
            android:layout_marginStart="325dp"
            android:background="@drawable/send_button_selector"
            android:fontFamily="@font/nexalight"
            android:paddingTop="10dp"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

        <EditText
            android:id="@+id/txtChatMessageContent"
            android:layout_width="301dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="5dp"
            android:background="@drawable/textview_rounded_corner_gray"
            android:ems="10"
            android:gravity="start"
            android:hint="@string/type_message"
            android:inputType="textMultiLine"
            android:lines="5"
            android:maxLines="20"
            android:minLines="3"
            android:paddingTop="10dp"
            android:textColor="@color/white"
            android:textColorHint="@color/light_gray"
            android:textSize="14sp"
            tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

    </androidx.cardview.widget.CardView>

    <ScrollView
        android:id="@+id/scrollView3"
        android:layout_width="409dp"
        android:layout_height="580dp"
        app:layout_constraintBottom_toTopOf="@+id/sendMessageCardView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="vertical"
            tools:layout_editor_absoluteY="1dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/chatHeaderCardView"
                android:layout_width="411dp"
                android:layout_height="57dp"
                app:cardBackgroundColor="@color/main_colour"
                app:cardElevation="5dp"
                app:layout_constraintBottom_toTopOf="@+id/chatRecyclerview"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0">

                <com.mikhaellopez.circularimageview.CircularImageView
                    android:id="@+id/imgChatHeaderProfilePicture"
                    android:layout_width="32dp"
                    android:layout_height="33dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="53dp"
                    android:background="@color/transparent_full"
                    app:civ_border_color="@color/white"
                    app:civ_border_width="1dp"
                    app:civ_shadow_color="@color/white"
                    app:civ_shadow_radius="5dp"
                    app:layout_constraintEnd_toStartOf="@+id/txtMessageUsername"
                    app:layout_constraintHorizontal_bias="0.571"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/imgChatHeaderOnlineStatus"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="75dp"
                    android:layout_marginTop="40dp"
                    android:background="@drawable/offline_icon"
                    app:civ_border_color="@color/white"
                    app:civ_border_width="1dp"
                    app:civ_shadow_color="@color/white"
                    app:civ_shadow_radius="5dp"
                    app:layout_constraintEnd_toStartOf="@+id/txtMessageUsername"
                    app:layout_constraintHorizontal_bias="0.814"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/imgChatUsernameTitle"
                    android:layout_width="164dp"
                    android:layout_height="31dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="90dp"
                    android:gravity="center_vertical"
                    android:text="@string/Cyberwizard"

                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imgChatHeaderGoBack"
                    android:layout_width="30dp"
                    android:layout_height="29dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="5dp"
                    app:srcCompat="@drawable/arrow_back" />
            </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/chatRecyclerview"
                android:layout_width="409dp"
                android:layout_height="0dp"
                android:layout_gravity="center_horizontal"
                android:layout_weight="5"
                android:background="@color/white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/showChatProgressView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.7"
                android:background="@color/black"
                android:clickable="false"
                android:elevation="1000dp"
                android:filterTouchesWhenObscured="false"
                android:foregroundGravity="center_vertical|center_horizontal"
                android:scaleType="fitCenter"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:targetApi="lollipop" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
