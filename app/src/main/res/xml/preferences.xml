<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <SwitchPreference
        android:id="@+id/biometricBiometricSwitch"
        android:defaultValue="false"
        android:icon="@drawable/fingerprint"
        android:key="@string/biometric_prompt_key"
        android:summary="@string/biometric_prompt_message"
        android:title="@string/biometric_prompt_key"
        />

    <SwitchPreference
        android:id="@+id/toggleDarkMode"
        android:defaultValue="false"
        android:icon="@drawable/dark_mode"
        android:key="@string/toggleDarkMode_key"
        android:summary="@string/toggle_dark_mode"
        android:title="@string/dark_mode"
        />





</PreferenceScreen>